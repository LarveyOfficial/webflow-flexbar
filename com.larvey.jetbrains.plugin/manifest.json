{
  "name": "JetBrains IDE",
  "uuid": "com.larvey.jetbrains",
  "version": "1.0.8",
  "author": "Larvey",
  "entry": "backend/plugin.cjs",
  "description": "JetBrains IDE integration for FlexBar — run, debug, stop, build, test, and git branch display. Requires companion plugin.",
  "repo": "https://github.com/LarveyOfficial/jetbrains-flexbar",
  "sdk": {
    "version": "1.0.0"
  },
  "software": {
    "minimumVersion": "1.0.0"
  },
  "os": [
    {
      "platform": "mac",
      "minimumVersion": "10.15"
    },
    {
      "platform": "windows",
      "minimumVersion": "10.0"
    },
    {
      "platform": "linux",
      "minimumVersion": "1.0"
    }
  ],
  "device": [
    {
      "name": "flexbar",
      "version": "1.0.0"
    }
  ],
  "configPage": "global_config",
  "keyLibrary": {
    "title": "JetBrains IDE",
    "style": {
      "icon": "mdi mdi-code-braces"
    },
    "children": [
      {
        "title": "$Run.Title",
        "tip": "$Run.Tip",
        "cid": "com.larvey.jetbrains.run",
        "config": {
          "keyType": "default",
          "clickable": true,
          "platform": ["mac", "windows", "linux"]
        },
        "style": {
          "icon": "mdi mdi-play-circle",
          "width": 200,
          "bgColor": "#2d6a4f",
          "fgColor": "#ffffff",
          "showIcon": true,
          "showTitle": true,
          "fontSize": 24,
          "iconSize": 42,
          "iconPos": { "X": 15, "Y": 50 },
          "titlePos": { "X": 62, "Y": 50 },
          "foregroundOutline": true
        },
        "data": { "configName": "", "port": 7123 }
      },
      {
        "title": "$Debug.Title",
        "tip": "$Debug.Tip",
        "cid": "com.larvey.jetbrains.debug",
        "config": {
          "keyType": "default",
          "clickable": true,
          "platform": ["mac", "windows", "linux"]
        },
        "style": {
          "icon": "mdi mdi-bug",
          "width": 200,
          "bgColor": "#b5500b",
          "fgColor": "#ffffff",
          "showIcon": true,
          "showTitle": true,
          "fontSize": 24,
          "iconSize": 42,
          "iconPos": { "X": 15, "Y": 50 },
          "titlePos": { "X": 62, "Y": 50 },
          "foregroundOutline": true
        },
        "data": { "configName": "", "port": 7123 }
      },
      {
        "title": "$Stop.Title",
        "tip": "$Stop.Tip",
        "cid": "com.larvey.jetbrains.stop",
        "config": {
          "keyType": "default",
          "clickable": true,
          "platform": ["mac", "windows", "linux"]
        },
        "style": {
          "icon": "mdi mdi-stop-circle",
          "width": 120,
          "bgColor": "#c62828",
          "fgColor": "#ffffff",
          "iconSize": 42,
          "iconPos": { "X": 50, "Y": 50 },
          "foregroundOutline": true
        },
        "data": { "port": 7123 }
      },
      {
        "title": "$Build.Title",
        "tip": "$Build.Tip",
        "cid": "com.larvey.jetbrains.build",
        "config": {
          "keyType": "default",
          "clickable": true,
          "platform": ["mac", "windows", "linux"]
        },
        "style": {
          "icon": "mdi mdi-hammer-wrench",
          "width": 120,
          "bgColor": "#1565c0",
          "fgColor": "#ffffff",
          "iconSize": 42,
          "iconPos": { "X": 50, "Y": 50 },
          "foregroundOutline": true
        },
        "data": { "port": 7123 }
      },
      {
        "title": "$Test.Title",
        "tip": "$Test.Tip",
        "cid": "com.larvey.jetbrains.test",
        "config": {
          "keyType": "default",
          "clickable": true,
          "platform": ["mac", "windows", "linux"]
        },
        "style": {
          "icon": "mdi mdi-test-tube",
          "width": 200,
          "bgColor": "#6a1b9a",
          "fgColor": "#ffffff",
          "showIcon": true,
          "showTitle": true,
          "fontSize": 24,
          "iconSize": 42,
          "iconPos": { "X": 15, "Y": 50 },
          "titlePos": { "X": 62, "Y": 50 },
          "foregroundOutline": true
        },
        "data": { "configName": "", "port": 7123 }
      },
      {
        "title": "$Branch.Title",
        "tip": "$Branch.Tip",
        "cid": "com.larvey.jetbrains.branch",
        "config": {
          "keyType": "default",
          "clickable": true,
          "platform": ["mac", "windows", "linux"]
        },
        "style": {
          "icon": "mdi mdi-source-branch",
          "width": 280,
          "bgColor": "#1e1e2e",
          "fgColor": "#89b4fa",
          "showIcon": true,
          "showTitle": true,
          "fontSize": 24,
          "iconSize": 42,
          "iconPos": { "X": 15, "Y": 50 },
          "titlePos": { "X": 62, "Y": 50 },
          "foregroundOutline": true
        },
        "data": { "port": 7123 }
      }
    ]
  },
  "local": {
    "en": {
      "Run": {
        "Title": "Run",
        "Tip": "Run the current or selected run configuration"
      },
      "Debug": {
        "Title": "Debug",
        "Tip": "Debug the current or selected run configuration"
      },
      "Stop": {
        "Title": "Stop",
        "Tip": "Stop all running processes"
      },
      "Build": {
        "Title": "Build",
        "Tip": "Build the project"
      },
      "Test": {
        "Title": "Test",
        "Tip": "Run the current or selected test configuration"
      },
      "Branch": {
        "Title": "Git Branch",
        "Tip": "Shows the current Git branch. Tap to refresh. Configure the project path in plugin settings."
      }
    }
  }
}
