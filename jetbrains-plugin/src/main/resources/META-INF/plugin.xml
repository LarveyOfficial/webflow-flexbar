<idea-plugin>
    <id>com.larvey.flexbar</id>
    <name>FlexBar Integration</name>
    <vendor>Larvey</vendor>
    <description>
        Exposes a local HTTP server on localhost:7123 so the FlexBar hardware
        can directly control your JetBrains IDE: run, debug, stop, build, and
        display the current Git branch and active run configuration.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.larvey.flexbar.FlexBarSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.larvey.flexbar.FlexBarConfigurable"
            id="com.larvey.flexbar.settings"
            displayName="FlexBar Integration"/>
        <postStartupActivity implementation="com.larvey.flexbar.FlexBarStartupActivity"/>
    </extensions>
</idea-plugin>
